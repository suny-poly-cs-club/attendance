# the email to use for ACME SSL certificate generation. only needed if using https
ACME_EMAIL=

# the domain to serve the app under. just the domain/IP, no http:// or paths
# api: https://<APP_HOST>/api/
# website: https://<APP_HOST>/
APP_HOST=

# postgres credentials
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# (optional: recommended to leave blank)
# POSTGRES_HOST=
# POSTGRES_PORT

# org specific message to display on the main screen
MESSAGE="ENTER ORGANIZATION SPECIFIC MESSAGE HERE"

# JWT tokens require a secret key to create an HMAC signature
# this should be a 64 character random string
# if you have openssl installed, you can generate one using: `openssl rand -hex 32`
JWT_SECRET=

# vim: ft=sh
